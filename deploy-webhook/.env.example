# Copy to deploy-webhook/.env on the server and keep it secret.
# Generate a secret: openssl rand -hex 32

# Required — must match the secret configured in the GitHub webhook.
GITHUB_WEBHOOK_SECRET=

# Branch to deploy on push (default: main)
DEPLOY_BRANCH=main

# Bind locally; nginx proxies public HTTPS traffic to this port.
DEPLOY_WEBHOOK_HOST=127.0.0.1
DEPLOY_WEBHOOK_PORT=9000

# Optional overrides
# REPO_ROOT=/var/www/user-management-app
# DEPLOY_LOG_DIR=/var/log/deploy-webhook
# NODE_VERSION=22.21.0
