# User Management App - Environment Variables Template
# Copy this file to .env and fill in your actual values

# JWT Secret Key — required in production (32+ random characters).
# Generate with: openssl rand -base64 32
JWT_SECRET=

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DATABASE_URL=./users.db

# CORS Configuration (for production)
CORS_ORIGIN=http://localhost:3000

# Security Settings
BCRYPT_ROUNDS=10

# Logging
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Podcast membership platform
# ---------------------------------------------------------------------------

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Default monthly subscription price (used when a user has no override price)
DEFAULT_SUBSCRIPTION_PRICE=9.99

# Absolute path where uploaded audio and images are stored on the server.
# Defaults to backend/uploads if unset.
UPLOAD_DIR=/var/www/user-management-app/backend/uploads

# Public base URL used to build RSS enclosure and stream links. In production
# this is the subpath origin.
BASE_URL=https://4thstate.ca/shyam_akaash

# Optional podcast channel metadata for the generated RSS feeds
PODCAST_TITLE=Shyam Akaash
PODCAST_AUTHOR=Shyam Akaash
PODCAST_EMAIL=podcast@4thstate.ca
# PODCAST_DESCRIPTION=Members-only audio from Shyam Akaash.
# Channel artwork for RSS/podcast apps (default: public/podcast-cover.jpg)
# PODCAST_COVER_FILE=podcast-cover.jpg
# PODCAST_IMAGE_URL=https://4thstate.ca/shyam_akaash/uploads/images/_podcast-channel.jpg
